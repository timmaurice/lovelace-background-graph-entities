{
  "name": "background-graph-entities",
  "version": "1.3.2",
  "description": "The `background-graph-entities` custom component for Home Assistant displays a list of entities with their current state and a mini graph showing the entity's history. This component is ideal for monitoring various sensor data, such as temperature, humidity, or other metrics.",
  "homepage": "https://github.com/timmaurice/lovelace-background-graph-entities#readme",
  "bugs": {
    "url": "https://github.com/timmaurice/lovelace-background-graph-entities/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/timmaurice/lovelace-background-graph-entities.git"
  },
  "license": "MIT",
  "author": "Tim Maurice Bayer",
  "type": "module",
  "main": "dist/background-graph-entities.js",
  "scripts": {
    "build": "rollup -c",
    "build:watch": "rollup -c -w",
    "check-format": "prettier --check .",
    "format": "prettier . --write",
    "lint": "eslint .",
    "dev": "npm-run-all --parallel build:watch demo",
    "demo": "serve -l 3000",
    "test": "NODE_ENV=production vitest run",
    "test:e2e": "docker compose -f docker-compose.e2e.yml up --build --exit-code-from playwright",
    "watch": "rollup -c -w"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/d3": "^7.4.3",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-lit": "^2.2.1",
    "eslint-plugin-wc": "^3.1.0",
    "globals": "^17.5.0",
    "jsdom": "^29.1.0",
    "lit": "^3.3.2",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.3",
    "rollup": "^4.60.2",
    "rollup-plugin-lit-css": "^6.0.1",
    "sass": "^1.99.0",
    "serve": "^14.2.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "d3-array": "^3.2.4",
    "d3-scale": "^4.0.2",
    "d3-selection": "^3.0.0",
    "d3-shape": "^3.2.0",
    "tslib": "^2.8.1",
    "vanilla-colorful": "^0.7.2"
  }
}
